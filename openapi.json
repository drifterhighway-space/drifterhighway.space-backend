{
    "openapi": "3.0.3",
    "info": {
        "title": "Drifter Highway Space API",
        "description": "EVE Online authentication and character management API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:3000",
            "description": "Local development server"
        },
        {
            "url": "https://drifterhighway.space",
            "description": "Production server"
        }
    ],
    "paths": {
        "/auth/eve/login": {
            "post": {
                "tags": ["Auth"],
                "summary": "EVE Online Login",
                "description": "Handle OAuth callback from EVE Online authentication. Exchange authorization code for EVE tokens, retrieve character ID from decoded token, create or update user and character records if they don't exist, and generate JWT token with 30-minute expiration.",
                "operationId": "LoginEve",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "string",
                                        "description": "OAuth authorization code from EVE Online"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful, JWT token returned",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "token": {
                                            "type": "string",
                                            "description": "JWT token string"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request - invalid code"
                    }
                }
            }
        },
        "/auth/eve/login/add": {
            "post": {
                "tags": ["Auth"],
                "summary": "Add EVE Character",
                "description": "Add an EVE character if the user exists, or update the refresh token for an existing character.",
                "operationId": "AddEve",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "string",
                                        "description": "OAuth authorization code from EVE Online"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Character added or refresh token updated successfully"
                    },
                    "201": {
                        "description": "Character created successfully"
                    },
                    "202": {
                        "description": "Character updated successfully"
                    },
                    "400": {
                        "description": "Invalid user"
                    },
                    "401": {
                        "description": "Unauthorized - valid JWT token required"
                    }
                }
            }
        },
        "/auth/discord/login": {
            "post": {
                "tags": ["Auth"],
                "summary": "Discord Login",
                "description": "Handle OAuth callback from Discord authentication. Future implementation will exchange Discord OAuth code for tokens, validate Discord user data, associate Discord account with EVE character, generate application JWT token, and return token to client.",
                "operationId": "LoginDiscord",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Discord login successful"
                    },
                    "401": {
                        "description": "Unauthorized - valid JWT token required"
                    }
                }
            }
        },
        "/maps/regions": {
            "get": {
                "tags": ["Maps", "Regions", "Constellations", "Solar Systems"],
                "summary": "Get All Regions",
                "description": "Retrieve all regions with counts of systems, constellations, observatories, and scouts. Each region includes the count of solar systems in it, constellations in it, systems with observatories, and characters who have scouted in that region.",
                "operationId": "GetRegions",
                "responses": {
                    "200": {
                        "description": "List of regions",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/RegionDTX"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/maps/regions/{id}": {
            "get": {
                "tags": ["Maps", "Regions", "Constellations", "Solar Systems"],
                "summary": "Get Region by ID",
                "description": "Retrieve a specific region by ID with counts of systems, constellations, observatories, and scout count.",
                "operationId": "GetRegion",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "Region ID"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Region found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/RegionDTX"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/maps/regions/{id}/scouts": {
            "get": {
                "tags": [
                    "Maps",
                    "Regions",
                    "Constellations",
                    "Solar Systems",
                    "Characters"
                ],
                "summary": "Get Scouts in Region",
                "description": "Retrieve all active characters who have scouted in any system within this region.",
                "operationId": "GetScoutsInRegion",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "Region ID"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of characters who have scouted in systems within this region",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/CharacterDTX"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/maps/svg/{name}": {
            "get": {
                "tags": ["Maps"],
                "summary": "Fetch Base Map SVG",
                "description": "Fetch a base SVG map from EveMaps/Dotlan",
                "operationId": "FetchBaseMapSVG",
                "parameters": [
                    {
                        "name": "name",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "Name of the map (e.g., eve_faction)"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "SVG map data returned"
                    }
                }
            }
        },
        "/maps/solarsystems": {
            "get": {
                "tags": ["Maps", "Solar Systems"],
                "summary": "Get All Solar Systems",
                "description": "Retrieve all solar systems from the database.",
                "operationId": "GetSolarSystems",
                "responses": {
                    "200": {
                        "description": "List of solar systems",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/SolarSystemDTX"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/characters": {
            "get": {
                "tags": ["Characters"],
                "summary": "Get All Characters",
                "description": "Retrieve all active characters from the database.",
                "operationId": "GetCharacters",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Which page of results to return",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1,
                            "minimum": 1
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "How many results to return",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 10,
                            "maximum": 100
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of characters",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Character"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - admin access required"
                    }
                }
            }
        },
        "/characters/{id}": {
            "get": {
                "tags": ["Characters"],
                "summary": "Get Character by ID",
                "description": "Retrieve a specific character by ID.",
                "operationId": "GetCharacter",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "Character ID"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Character found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Character"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - not admin or character owner"
                    }
                }
            },
            "put": {
                "tags": ["Characters"],
                "summary": "Update Character",
                "description": "Update a character by ID.",
                "operationId": "UpdateCharacter",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "Character ID"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CharacterUpdate"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Character updated successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Character"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - not admin or character owner"
                    }
                }
            },
            "delete": {
                "tags": ["Characters"],
                "summary": "Delete Character",
                "description": "Delete (soft delete) a character by ID. Character is marked as Inactive.",
                "operationId": "DeleteCharacter",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "Character ID"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Character deleted successfully"
                    },
                    "401": {
                        "description": "Unauthorized - not admin or character owner"
                    }
                }
            }
        },
        "/users": {
            "get": {
                "tags": ["Users"],
                "summary": "Get All Users",
                "description": "Retrieve all active users from the database.",
                "operationId": "GetUsers",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of users",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/User"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - admin access required"
                    },
                    "404": {
                        "description": "No users found"
                    }
                }
            }
        },
        "/users/{id}": {
            "get": {
                "tags": ["Users"],
                "summary": "Get User by ID",
                "description": "Retrieve a specific user by ID.",
                "operationId": "GetUser",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "User ID"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/User"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - not admin or user owner"
                    }
                }
            },
            "put": {
                "tags": ["Users"],
                "summary": "Update User",
                "description": "Update a user by ID.",
                "operationId": "UpdateUser",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "User ID"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/UserUpdate"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "User updated successfully"
                    },
                    "401": {
                        "description": "Unauthorized - not admin or user owner"
                    }
                }
            },
            "delete": {
                "tags": ["Users"],
                "summary": "Delete User",
                "description": "Delete (soft delete) a user by ID. User is marked as Inactive.",
                "operationId": "DeleteUser",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "User ID"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User deleted successfully"
                    },
                    "401": {
                        "description": "Unauthorized - not admin or user owner"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "description": "JWT Bearer Token for authentication"
            }
        },
        "schemas": {
            "JWTToken": {
                "type": "object",
                "description": "JWT authentication token returned on successful login",
                "properties": {
                    "token": {
                        "type": "string",
                        "description": "The JWT token string"
                    }
                }
            },
            "RegionDTX": {
                "type": "object",
                "description": "Region data transfer object with counts of systems, constellations, observatories, and scouts",
                "properties": {
                    "ID": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Unique identifier for the region"
                    },
                    "Name": {
                        "type": "string",
                        "description": "Name of the region"
                    },
                    "SystemCount": {
                        "type": "integer",
                        "description": "Number of solar systems in this region"
                    },
                    "ConstellationCount": {
                        "type": "integer",
                        "description": "Number of constellations in this region"
                    },
                    "ObservatoryCount": {
                        "type": "integer",
                        "description": "Number of systems with observatories in this region"
                    },
                    "ScoutCount": {
                        "type": "integer",
                        "description": "Number of characters who have scouted in systems within this region"
                    }
                }
            },
            "CharacterDTX": {
                "type": "object",
                "description": "Character data transfer object for scout listing",
                "properties": {
                    "ID": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Unique identifier for the character"
                    },
                    "Name": {
                        "type": "string",
                        "description": "Name of the character"
                    },
                    "SolarSystemID": {
                        "type": "integer",
                        "format": "int64",
                        "description": "The last system this character scouted"
                    }
                }
            },
            "SolarSystemDTX": {
                "type": "object",
                "description": "Solar system data transfer object",
                "properties": {
                    "ID": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Unique identifier for the solar system"
                    },
                    "Name": {
                        "type": "string",
                        "description": "Name of the solar system"
                    },
                    "RegionID": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Region ID this system belongs to"
                    },
                    "ConstellationID": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Constellation ID this system belongs to"
                    }
                }
            },
            "User": {
                "type": "object",
                "description": "User entity from the database",
                "properties": {
                    "ID": {
                        "type": "string",
                        "description": "Unique identifier for the user"
                    },
                    "Name": {
                        "type": "string",
                        "description": "Name of the user"
                    },
                    "Status": {
                        "type": "string",
                        "description": "Status of the user",
                        "enum": ["Active", "Inactive"]
                    },
                    "DiscordID": {
                        "type": "string",
                        "description": "Optional Discord ID for the user"
                    }
                }
            },
            "UserUpdate": {
                "type": "object",
                "description": "Request body for updating a user",
                "properties": {
                    "Name": {
                        "type": "string",
                        "description": "New name for the user"
                    },
                    "DiscordID": {
                        "type": "string",
                        "description": "Discord ID for the user"
                    }
                }
            },
            "Character": {
                "type": "object",
                "description": "Character entity from the database",
                "properties": {
                    "ID": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Unique identifier for the character"
                    },
                    "Name": {
                        "type": "string",
                        "description": "Name of the character"
                    },
                    "User": {
                        "type": "string",
                        "description": "ID of the user who owns this character"
                    },
                    "Corporation": {
                        "type": "object",
                        "description": "Associated corporation",
                        "properties": {
                            "ID": {
                                "type": "integer",
                                "format": "int64",
                                "description": "Corporation ID"
                            },
                            "Name": {
                                "type": "string",
                                "description": "Corporation name"
                            },
                            "Type": {
                                "type": "string",
                                "description": "Type of group entity",
                                "enum": ["Corporation", "Alliance"]
                            }
                        }
                    },
                    "Status": {
                        "type": "string",
                        "description": "Status of the character",
                        "enum": [
                            "Active",
                            "Inactive",
                            "InvalidToken",
                            "Pending",
                            "ManualAdd"
                        ]
                    },
                    "RefreshToken": {
                        "type": "object",
                        "description": "Optional refresh token for authentication",
                        "properties": {
                            "Token": {
                                "type": "string"
                            },
                            "Type": {
                                "type": "string"
                            },
                            "Expires": {
                                "type": "string",
                                "format": "date-time"
                            },
                            "Scopes": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "AccessToken": {
                        "type": "object",
                        "description": "Optional access token for authentication",
                        "properties": {
                            "Token": {
                                "type": "string"
                            },
                            "Type": {
                                "type": "string"
                            },
                            "Expires": {
                                "type": "string",
                                "format": "date-time"
                            },
                            "Scopes": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "Location": {
                        "type": "object",
                        "description": "Optional location data",
                        "properties": {
                            "ID": {
                                "type": "integer",
                                "format": "int64"
                            },
                            "SolarSystemID": {
                                "type": "integer",
                                "format": "int64"
                            }
                        }
                    },
                    "Ship": {
                        "type": "object",
                        "description": "Optional ship owned by this character",
                        "properties": {
                            "ID": {
                                "type": "integer",
                                "format": "int64"
                            },
                            "Name": {
                                "type": "string"
                            },
                            "TypeName": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "CharacterUpdate": {
                "type": "object",
                "description": "Request body for updating a character",
                "properties": {
                    "Name": {
                        "type": "string",
                        "description": "New name for the character"
                    }
                }
            }
        }
    }
}
