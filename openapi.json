    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "description": "JWT Bearer Token for authentication"
            }
        },
        "schemas": {
            "JWTToken": {
                "type": "object",
                "description": "JWT authentication token returned on successful login",
                "properties": {
                    "token": {
                        "type": "string",
                        "description": "The JWT token string"
                    }
                }
            },
            "User": {
                "type": "object",
                "description": "User entity from the database",
                "properties": {
                    "ID": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Unique identifier for the user"
                    },
                    "Name": {
                        "type": "string",
                        "description": "Name of the user"
                    },
                    "Status": {
                        "type": "string",
                        "description": "Status of the user (Active/Inactive)",
                        "enum": ["Active", "Inactive"]
                    },
                    "DiscordID": {
                        "type": "string",
                        "description": "Optional Discord ID for the user"
                    }
                }
            },
            "UserUpdate": {
                "type": "object",
                "description": "Request body for updating a user",
                "properties": {
                    "Name": {
                        "type": "string",
                        "description": "New name for the user"
                    },
                    "DiscordID": {
                        "type": "string",
                        "description": "Discord ID for the user"
                    }
                }
            },
            "Character": {
                "type": "object",
                "description": "Character entity from the database",
                "properties": {
                    "ID": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Unique identifier for the character"
                    },
                    "Name": {
                        "type": "string",
                        "description": "Name of the character"
                    },
                    "User": {
                        "type": "integer",
                        "format": "int64",
                        "description": "ID of the user who owns this character"
                    },
                    "Corporation": {
                        "type": "object",
                        "description": "Associated corporation",
                        "properties": {
                            "ID": {
                                "type": "integer",
                                "format": "int64",
                                "description": "Corporation ID"
                            },
                            "Name": {
                                "type": "string",
                                "description": "Corporation name"
                            }
                        }
                    },
                    "Status": {
                        "type": "string",
                        "description": "Status of the character",
                        "enum": [
                            "Active",
                            "Inactive",
                            "InvalidToken",
                            "Pending"
                        ]
                    },
                    "RefreshToken": {
                        "type": "string",
                        "description": "Optional refresh token for authentication"
                    },
                    "AccessToken": {
                        "type": "string",
                        "description": "Optional access token for authentication"
                    },
                    "Ship": {
                        "type": "object",
                        "description": "Optional ship owned by this character",
                        "properties": {
                            "ID": {
                                "type": "integer",
                                "format": "int64"
                            },
                            "Name": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "CharacterUpdate": {
                "type": "object",
                "description": "Request body for updating a character",
                "properties": {
                    "Name": {
                        "type": "string",
                        "description": "New name for the character"
                    }
                }
            },
            "Corporation": {
                "type": "object",
                "description": "Corporation entity from the database",
                "properties": {
                    "ID": {
                        "type": "integer",
                        "format": "int64",
                        "description": "Unique identifier for the corporation"
                    },
                    "Name": {
                        "type": "string",
                        "description": "Name of the corporation"
                    },
                    "Type": {
                        "type": "string",
                        "description": "Type of group entity (Corporation/Alliance)",
                        "enum": ["Corporation", "Alliance"]
                    },
                    "Parent": {
                        "type": "object",
                        "description": "Optional parent group entity reference",
                        "properties": {
                            "ID": {
                                "type": "integer",
                                "format": "int64"
                            },
                            "Name": {
                                "type": "string"
                            },
                            "Type": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "CorporationUpdate": {
                "type": "object",
                "description": "Request body for updating a corporation",
                "properties": {
                    "Name": {
                        "type": "string",
                        "description": "New name for the corporation"
                    }
                }
            }
        }
    }
}
