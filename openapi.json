{
    "openapi": "3.0.3",
    "info": {
        "title": "Drifter Highway Space API",
        "description": "EVE Online authentication and character management API",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://localhost:3000",
            "description": "Local development server"
        },
        {
            "url": "https://drifterhighway.space",
            "description": "Production server"
        }
    ],
    "paths": {
        "/auth/eve/login": {
            "post": {
                "tags": ["Authentication"],
                "summary": "EVE Online Login",
                "description": "Handle OAuth callback from EVE Online authentication. Exchange authorization code for EVE tokens, retrieve character ID from decoded token, create or update user and character records if they don't exist, and generate JWT token with 30-minute expiration. Returns the application JWT token to the client.",
                "operationId": "LoginEve",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "string",
                                        "description": "OAuth authorization code from EVE Online"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Login successful, JWT token returned",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/JWTToken"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error - user or character insertion failed"
                    }
                }
            }
        },
        "/auth/eve/login/add": {
            "post": {
                "tags": ["Authentication"],
                "summary": "Add EVE Character",
                "description": "Add an EVE character if the user exists, or update the refresh token for an existing character. Checks if character exists in database, creates new character record if it doesn't exist, or updates refreshToken if character exists. Both features are currently marked as TODO in implementation.",
                "operationId": "AddEve",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Character added or refresh token updated successfully"
                    },
                    "401": {
                        "description": "Unauthorized - valid JWT token required"
                    }
                }
            }
        },
        "/auth/discord/login": {
            "post": {
                "tags": ["Authentication"],
                "summary": "Discord Login",
                "description": "Handle OAuth callback from Discord authentication. Currently under development. Future implementation will exchange Discord OAuth code for tokens, validate Discord user data, associate Discord account with EVE character, generate application JWT token, and return token to client. Requires authentication for OAuth callback handling.",
                "operationId": "LoginDiscord",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Discord login successful"
                    },
                    "401": {
                        "description": "Unauthorized - valid JWT token required"
                    }
                }
            }
        },
        "/characters": {
            "get": {
                "tags": ["Characters"],
                "summary": "Get All Characters",
                "description": "Retrieve all active characters from the database.",
                "operationId": "GetCharacters",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "Which page of results to return",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 1,
                            "minimum": 1
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "How many results to return",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "default": 10,
                            "maximum": 100
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of characters",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/Character"
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized - valid JWT token required"
                    },
                    "404": {
                        "description": "No characters found"
                    }
                }
            },
            "put": {
                "tags": ["Characters"],
                "summary": "Update Character",
                "description": "Update a character by ID.",
                "operationId": "UpdateCharacter",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        },
                        "description": "Character ID"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CharacterUpdate"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Character updated successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Character"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "tags": ["Characters"],
                "summary": "Delete Character",
                "description": "Delete (deactivate) a character by ID. Character is marked as Inactive.",
                "operationId": "DeleteCharacter",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "format": "int64"
                        },
                        "description": "Character ID"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Character deleted successfully"
                    },
                    "401": {
                        "description": "Unauthorized"
                    }
                }
            }
        },
